{
  "buildCommand": "npm run build:prod",
  "installCommand": "npm install --ignore-scripts",
  "outputDirectory": "dist/makertags/browser",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/makertags/{server,browser/assets/i18n}/**"
    }
  },
  "routes": [
    {
      "src": "^/\\.netlify/functions/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/ssr"
    }
  ]
}
