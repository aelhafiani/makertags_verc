{
  "buildCommand": "npm run build:prod",
  "installCommand": "npm install --ignore-scripts",
  "outputDirectory": "dist/makertags/browser",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/makertags/server/**"
    }
  },
  "routes": [
    { "src": "^/$", "dest": "/api/ssr" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/ssr" }
  ]
}
