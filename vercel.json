{
  "buildCommand": "npm run build:prod",
  "installCommand": "npm install",
  "outputDirectory": "dist/makertags/browser",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/makertags/{server,browser/assets/i18n}/**"
    },
    "api/[...slug].js": {
      "includeFiles": "netlify/functions/**"
    }
  },
  "headers": [
    {
      "source": "/(.*\\.js)$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*\\.css)$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/\\.netlify/functions/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/ssr"
    }
  ]
}
